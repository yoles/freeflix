{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testRegex": "\\.e2e\\.test\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverage": false,
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@src/(.*)$": "<rootDir>/$1",
    "^@movies/(.*)$": "<rootDir>/movies/$1"
  }
}
